# LangGraph4J 环境变量配置示例
# 复制此文件为 .env 并修改配置

# ============================================
# LLM 配置
# ============================================

# OpenAI API Key (必需)
OPENAI_API_KEY=your_openai_api_key_here

# LLM 基础 URL (可选，默认为 OpenAI)
LLM_BASE_URL=https://api.openai.com/v1

# LLM 模型 (可选，默认为 gpt-3.5-turbo)
LLM_MODEL=gpt-3.5-turbo

# ============================================
# Embedding 配置
# ============================================

# Embedding 基础 URL (可选，默认使用 LLM_BASE_URL)
EMBEDDING_BASE_URL=https://api.openai.com/v1

# Embedding API Key (可选，默认使用 OPENAI_API_KEY)
EMBEDDING_API_KEY=your_openai_api_key_here

# Embedding 模型 (可选，默认为 text-embedding-3-small)
EMBEDDING_MODEL=text-embedding-3-small

# Embedding 维度 (可选，默认为 1536)
EMBEDDING_DIMENSIONS=1536

# ============================================
# Redis 配置
# ============================================

# Redis 连接 URI (可选，默认为本地)
REDIS_URI=redis://localhost:6379

# ============================================
# PostgreSQL + PGVector 配置
# ============================================

# PostgreSQL JDBC URL
PGVECTOR_URL=jdbc:postgresql://localhost:5432/langgraph4j

# PostgreSQL 用户名
PGVECTOR_USER=postgres

# PostgreSQL 密码 (必需)
PGVECTOR_PASSWORD=your_postgres_password

# ============================================
# 服务配置
# ============================================

# 后端服务端口 (可选，默认为 8080)
SERVER_PORT=8080

# 前端服务端口 (可选，默认为 3000)
FRONTEND_PORT=3000
